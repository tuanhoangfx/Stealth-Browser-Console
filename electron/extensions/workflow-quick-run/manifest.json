{
  "manifest_version": 3,
  "name": "Stealth Workflow Quick Run",
  "version": "0.1.0",
  "description": "Workflow quick run side panel (Phase 0 spike)",
  "permissions": ["sidePanel", "storage"],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*"],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "commands": {
    "toggle-workflow-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "Open workflow quick run panel"
    }
  },
  "action": {
    "default_title": "Workflow Quick Run",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png"
  }
}
